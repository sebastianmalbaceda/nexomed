generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  NURSE
  DOCTOR
  TCAE
}

enum PatientStatus {
  ESTABLE
  MODERADO
  CRITICO
  OBSERVACION
}

enum DiagnosticTestType {
  LAB
  IMAGING
}

enum DiagnosticTestStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum CareRecordType {
  constante
  cura
  higiene
  balance
  ingesta
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  role         Role
  name         String
  shift        String?        // morning, afternoon, night (solo para NURSE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notifications    Notification[]
  prescribedMeds  Medication[]    @relation("PrescribedBy")
  administeredSchedules MedSchedule[] @relation("AdministeredBy")
  recordedCareRecords   CareRecord[]   @relation("RecordedBy")
  reportedIncidents     Incident[]     @relation("ReportedBy")
  requestedTests       DiagnosticTest[] @relation("RequestedBy")
  reviewedTests        DiagnosticTest[] @relation("ReviewedBy")
  assignedPatients    Patient[]        @relation("AssignedNurse")
}

model Patient {
  id                   String           @id @default(uuid())
  name                 String
  dob                  DateTime
  diagnosis            String
  allergies            String[]         // Array nativo de PostgreSQL
  admissionDate        DateTime         @default(now())
  bedId                String?          @unique
  dietRestriction      String?
  dni                  String?          @unique
  isolationRestriction String?
  mobilityRestriction  String?
  dischargeDate        DateTime?
  discharged           Boolean          @default(false)
  surnames             String?
  status               PatientStatus    @default(ESTABLE)
  assignedNurseId      String?
  assignedNurse        User?            @relation("AssignedNurse", fields: [assignedNurseId], references: [id])
  careRecords          CareRecord[]
  diagnosticTests      DiagnosticTest[]
  incidents            Incident[]
  medications          Medication[]
  notifications        Notification[]
  bed                  Bed?             @relation(fields: [bedId], references: [id])
}

model Bed {
  id      String   @id @default(uuid())
  room    Int
  letter  String
  floor   Int      @default(1)
  patient Patient?

  @@unique([room, letter])
}

model Medication {
  id             String        @id @default(uuid())
  patientId      String
  drugName       String
  nregistro      String?
  dose           String
  route          String
  frequencyHrs   Int
  startTime      DateTime
  active         Boolean       @default(true)
  prescribedById String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  schedules      MedSchedule[]
  patient        Patient       @relation(fields: [patientId], references: [id])
  prescribedBy   User          @relation("PrescribedBy", fields: [prescribedById], references: [id])
}

model MedSchedule {
  id               String     @id @default(uuid())
  medicationId     String
  scheduledAt      DateTime
  administeredAt   DateTime?
  administeredById String?
  administeredBy   User?      @relation("AdministeredBy", fields: [administeredById], references: [id])
  medication       Medication @relation(fields: [medicationId], references: [id])
}

model CareRecord {
  id           String   @id @default(uuid())
  patientId    String
  type         CareRecordType
  value        String
  unit         String?
  notes        String?
  recordedById String
  recordedAt   DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id])
  recordedBy   User     @relation("RecordedBy", fields: [recordedById], references: [id])
}

model Notification {
  id               String          @id @default(uuid())
  userId           String
  type             String
  message          String
  relatedPatientId String?
  relatedTestId    String?
  read             Boolean         @default(false)
  createdAt        DateTime        @default(now())
  patient          Patient?        @relation(fields: [relatedPatientId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  relatedTest      DiagnosticTest? @relation(fields: [relatedTestId], references: [id])
}

model Incident {
  id           String   @id @default(uuid())
  patientId    String
  type         String
  description  String
  reportedById String
  reportedAt   DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id])
  reportedBy   User     @relation("ReportedBy", fields: [reportedById], references: [id])
}

model DiagnosticTest {
  id            String           @id @default(uuid())
  patient       Patient          @relation(fields: [patientId], references: [id])
  patientId     String
  type          DiagnosticTestType
  name          String
  scheduledAt   DateTime
  result        String?
  status        DiagnosticTestStatus @default(REQUESTED)
  requestedBy   User            @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById String
  reviewedBy   User?           @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedById  String?
  createdAt     DateTime         @default(now())
  notifications Notification[]
}
