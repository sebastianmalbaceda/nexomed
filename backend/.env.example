# ============================================================
# NexoMed Backend — Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:5432/nexomed?sslmode=require"

# Secreto para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET="cambia_esto_por_un_secreto_seguro_de_minimo_32_chars"

# Duración de los tokens JWT (8h = duración de un turno)
JWT_EXPIRES_IN="8h"

# Puerto del servidor Express
PORT=3000

# Origen permitido por CORS (URL del frontend en desarrollo)
CORS_ORIGIN="http://localhost:5173"

# Entorno de ejecución (development | production | test)
NODE_ENV="development"