# ============================================================
# NexoMed — Variables de Entorno de Ejemplo
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- BACKEND ---

# URL de conexión a PostgreSQL (Neon o local)
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
# Para desarrollo local con SQLite (no recomendado): file:./nexomed.db
DATABASE_URL="postgresql://user:password@localhost:5432/nexomed"

# Secreto para firmar tokens JWT (mínimo 32 caracteres, usa un generador aleatorio)
JWT_SECRET="8f2d1a69adefdd37521f9f7b1239097507036df3e4ad97885972b9ec4fe555de"

# Duración de los tokens JWT (8h = duración de un turno hospitalario)
JWT_EXPIRES_IN="8h"

# Puerto del servidor Express (estándar: 3000)
# Si el puerto está ocupado, el servidor usa automáticamente PORT+1
PORT=3000

# Origen permitido por CORS (URL del frontend en desarrollo, separar múltiples con coma)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# --- FRONTEND ---

# URL base de la API REST del backend
VITE_API_URL="http://localhost:3000/api"

# --- EXTERNAL APIs ---

# URL base de la API CIMA/AEMPS (medicamentos) — pública, no requiere key
CIMA_BASE_URL="https://cima.aemps.es/cima/rest"

# --- DESARROLLO ---

# Entorno de ejecución (development | production | test)
NODE_ENV="development"
